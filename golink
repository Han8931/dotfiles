#!/usr/bin/env bash
set -euo pipefail

browser=${browser:-firefox}
urls_file="${HOME}/.dotfiles/urls.txt"   # CSV: name,URL

# Extract choices (left side, trimmed), skip blanks/comments
choices=$(awk -F',' 'NF && $1 !~ /^[[:space:]]*#/ {
  name=$1; sub(/^[[:space:]]+/,"",name); sub(/[[:space:]]+$/,"",name);
  print name
}' "$urls_file")

# dmenu to pick a name
chosen=$(printf '%s\n' "$choices" | dmenu -i -p "Go to ...")
[ -z "$chosen" ] && { echo "No option was chosen." >&2; exit 1; }

# Look up URL by chosen name (CSV-aware)
url=$(awk -F',' -v chosen="$chosen" '
  NF {
    name=$1; sub(/^[[:space:]]+/,"",name); sub(/[[:space:]]+$/,"",name);
    if (name == chosen) {
      url=$2; for (i=3;i<=NF;i++) url=url FS $i;  # in case commas ever appear later
      sub(/^[[:space:]]+/,"",url); sub(/[[:space:]]+$/,"",url);
      print url; exit
    }
  }
' "$urls_file")

# If no URL found, ask and append using a COMMA (not a space!)
if [ -z "$url" ]; then
  echo "No URL found for: $chosen"
  new_url=$(dmenu -p "Enter new URL for $chosen:")
  if [ -n "$new_url" ]; then
    printf '%s,%s\n' "$chosen" "$new_url" >> "$urls_file"
    url=$new_url
  else
    echo "No URL entered. Exiting."; exit 1
  fi
fi

# If the URL ends with '=', prompt for a query and append it
if [[ "$url" == *"=" ]]; then
  search_terms=$(dmenu -p "Enter search terms:")
  if [ -n "$search_terms" ]; then
    encoded_terms=${search_terms// /+}
    full_url="${url}${encoded_terms}"
  else
    full_url="${url%/*}/"
  fi
else
  full_url="$url"
fi

# Open
"$browser" "$full_url" >/dev/null 2>&1 &
